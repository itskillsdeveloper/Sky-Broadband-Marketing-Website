# Base URL of the ISP Billing app that serves the website content API.
# The site fetches:  ${VITE_API_URL}/api/website/content
#
# Local dev (billing app running locally):
#   VITE_API_URL=http://localhost:4118
# Production (billing app reachable over HTTPS):
#   VITE_API_URL=https://billing.yourdomain.com
VITE_API_URL=http://localhost:4118
